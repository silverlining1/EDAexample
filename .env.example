# EDA Toolkit Configuration
# Copy this file to .env and fill in your values

DATA_FILE=data/sample_facebook.csv
OUTPUT_DIR=outputs
LOG_LEVEL=INFO

# Column name mappings — update these to match your CSV headers
DATE_COLUMN=Publish time
ID_COLUMN=Video asset ID
DURATION_COLUMN=Duration (sec)
PAGE_COLUMN=Page name
TOP_N_PAGES=10
